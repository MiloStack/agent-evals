{
  "name": "agent-evals",
  "version": "0.1.0",
  "description": "Evaluate AI coding agent outputs against quality checks",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "bin": {
    "agent-evals": "./dist/cli.js"
